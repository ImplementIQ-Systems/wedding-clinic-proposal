<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wedding Clinic — Proposta Dark</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet">
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Jost',sans-serif;color:#2c2825;background:#faf8f5}
  nav{display:flex;align-items:center;justify-content:space-between;padding:18px 48px;background:#faf8f5;border-bottom:0.5px solid #e0dbd4;position:sticky;top:0;z-index:100}
  .logo{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:300;letter-spacing:0.15em;color:#2c2825}
  .nav-links{display:flex;gap:32px}
  .nav-links a{font-size:11px;font-weight:300;letter-spacing:0.12em;color:#6b6460;text-decoration:none;text-transform:uppercase}
  .nav-links a:hover{color:#2c2825}
  .hero{position:relative;height:560px;background:#1e1612;display:flex;align-items:center;justify-content:center;overflow:hidden}
  .hero-img{position:absolute;inset:0;background-image:url('https://static.wixstatic.com/media/15b38d_03e3cc5643794a8fbfa5de9a2d686bf9~mv2.jpeg/v1/fill/w_305,h_458,al_c,q_80,enc_avif,quality_auto/15b38d_03e3cc5643794a8fbfa5de9a2d686bf9~mv2.jpeg');background-size:cover;background-position:center top;opacity:0.22}
  .hero-content{position:relative;text-align:center;padding:0 32px}
  .hero-tag{font-size:10px;letter-spacing:0.28em;color:#c9a96e;text-transform:uppercase;margin-bottom:18px;font-weight:300}
  .hero-title{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:300;color:#f5f0e8;line-height:1.15;font-style:italic;margin-bottom:14px}
  .hero-sub{font-size:12px;font-weight:300;letter-spacing:0.14em;color:#b8a898;margin-bottom:36px;text-transform:uppercase}
  .btn{display:inline-block;padding:13px 36px;border:0.5px solid #c9a96e;color:#c9a96e;font-size:11px;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-weight:300;background:transparent;text-decoration:none;transition:all 0.25s}
  .btn:hover{background:#c9a96e;color:#2c2825}
  .btn-light{border-color:#f5f0e8;color:#f5f0e8;margin-left:14px}
  .btn-light:hover{background:#f5f0e8;color:#2c2825}
  .btn-dark{border-color:#2c2825;color:#2c2825}
  .btn-dark:hover{background:#2c2825;color:#faf8f5}
  .info-strip{background:#2c2825;padding:44px 48px;display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
  .info-item{text-align:center}
  .info-icon{font-size:14px;margin-bottom:12px;color:#c9a96e;letter-spacing:0.3em}
  .info-title{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:300;color:#f5f0e8;font-style:italic;margin-bottom:6px}
  .info-text{font-size:11px;color:#8a7d74;font-weight:300;letter-spacing:0.06em;line-height:1.7}
  .section{padding:64px 48px}
  .section-label{font-size:10px;letter-spacing:0.28em;color:#c9a96e;text-transform:uppercase;margin-bottom:8px;font-weight:300}
  .section-title{font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:300;color:#2c2825;font-style:italic;margin-bottom:8px}
  .section-desc{font-size:13px;color:#8a7d74;font-weight:300;line-height:1.75;max-width:500px;margin-bottom:44px}
  .catalog-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
  .dress-card{cursor:pointer;position:relative}
  .dress-img{width:100%;aspect-ratio:2/3;overflow:hidden;background:#e8e2db;position:relative}
  .dress-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.65s cubic-bezier(0.25,0.46,0.45,0.94);display:block}
  .dress-card:hover .dress-img img{transform:scale(1.07)}
  .dress-overlay{position:absolute;inset:0;background:rgba(28,22,18,0);display:flex;align-items:center;justify-content:center;transition:background 0.35s}
  .dress-card:hover .dress-overlay{background:rgba(28,22,18,0.48)}
  .overlay-btn{opacity:0;transform:translateY(10px);transition:all 0.3s;font-size:10px;letter-spacing:0.18em;color:#f5f0e8;border:0.5px solid #f5f0e8;padding:9px 20px;text-transform:uppercase;font-weight:300}
  .dress-card:hover .overlay-btn{opacity:1;transform:translateY(0)}
  .dress-name{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:300;color:#2c2825;margin-top:12px;font-style:italic}
  .dress-tag{font-size:10px;letter-spacing:0.1em;color:#a09288;font-weight:300;margin-top:3px;text-transform:uppercase}
  .marcacao{background:#f2ede6;padding:56px 48px;text-align:center}
  .marcacao .section-desc{margin:0 auto 32px}
  footer{background:#1a1008;padding:36px 48px;display:flex;align-items:center;justify-content:space-between}
  .footer-logo{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:300;color:#f5f0e8;letter-spacing:0.15em;font-style:italic}
  .footer-info{font-size:11px;color:#6b6460;font-weight:300;line-height:1.9;text-align:center}
  .footer-social{display:flex;gap:12px}
  .social-btn{width:30px;height:30px;border:0.5px solid #3a3028;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:11px;color:#6b6460;transition:all 0.2s;font-weight:300}
  .social-btn:hover{border-color:#c9a96e;color:#c9a96e}
  .wa-btn{position:fixed;bottom:24px;right:24px;width:48px;height:48px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:22px;box-shadow:0 4px 14px rgba(37,211,102,0.3);z-index:200;transition:transform 0.2s}
  .wa-btn:hover{transform:scale(1.08)}
  .badge{display:inline-block;padding:3px 12px;background:#f2ede6;border:0.5px solid #d4c4b4;font-size:9px;letter-spacing:0.14em;color:#8a7d74;text-transform:uppercase;cursor:pointer;transition:all 0.2s}
  .badge.active,.badge:hover{background:#2c2825;color:#c9a96e;border-color:#2c2825}
  .catalog-header{padding:44px 48px 20px;border-bottom:0.5px solid #e0dbd4;display:flex;align-items:flex-end;justify-content:space-between}
  .filters{display:flex;gap:8px}
  @media(max-width:700px){
    nav{padding:14px 20px}.nav-links{display:none}
    .hero{height:420px}.hero-title{font-size:36px}
    .info-strip{grid-template-columns:1fr;padding:32px 20px}
    .section{padding:44px 20px}.catalog-grid{grid-template-columns:repeat(2,1fr)}
    .marcacao{padding:40px 20px}footer{flex-direction:column;gap:20px;text-align:center;padding:28px 20px}
    .catalog-header{flex-direction:column;align-items:flex-start;gap:16px;padding:32px 20px 16px}
  }
</style>
</head>
<body>

<nav>
