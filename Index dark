<div class="wa-btn" title="WhatsApp">💬</div>

<script>
  document.querySelectorAll('.badge').forEach(function(b){
    b.addEventListener('click',function(){
      document.querySelectorAll('.badge').forEach(function(x){x.classList.remove('active')});
      b.classList.add('active');
    });
  });
</script>
</body>
</html>
